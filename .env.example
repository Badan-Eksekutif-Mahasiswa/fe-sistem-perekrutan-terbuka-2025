# Backend API Configuration
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional Supabase Storage for event media upload.
# Leave empty to disable uploads and use manual image URLs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=spt-media

# Environment
NODE_ENV=development
